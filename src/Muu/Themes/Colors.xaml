<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fog / Mist theme: 霧 → む → muu -->
    <!-- Window background is transparent; fog + cells float on desktop -->
    <Color x:Key="WindowBackgroundColor">#00000000</Color>
    <Color x:Key="InputBackgroundColor">#30FFFFFF</Color>
    <Color x:Key="SelectedItemColor">#30FFFFFF</Color>
    <Color x:Key="HoverItemColor">#18FFFFFF</Color>
    <Color x:Key="CellBackgroundColor">#20FFFFFF</Color>
    <Color x:Key="PrimaryTextColor">#E0E4E8</Color>
    <Color x:Key="SecondaryTextColor">#8090A0</Color>
    <Color x:Key="TertiaryTextColor">#506070</Color>
    <Color x:Key="BorderColor">#25FFFFFF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="SelectedItemBrush" Color="{StaticResource SelectedItemColor}" />
    <SolidColorBrush x:Key="HoverItemBrush" Color="{StaticResource HoverItemColor}" />
    <SolidColorBrush x:Key="CellBackgroundBrush" Color="{StaticResource CellBackgroundColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="{StaticResource TertiaryTextColor}" />
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="{StaticResource BorderColor}" />

</ResourceDictionary>
