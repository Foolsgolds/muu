<Window x:Class="Muu.Views.GridItemSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Muu - スロット設定"
        Width="460" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E4E4E4" />
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#E4E4E4" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CaretBrush" Value="#E4E4E4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="#E4E4E4" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Text="名前" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="NameBox" />

        <!-- Target Path -->
        <TextBlock Grid.Row="2" Text="パス" />
        <TextBox Grid.Row="2" Grid.Column="1"
                 x:Name="PathBox" Margin="0,0,8,0" />
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
            <Button Content="ファイル..." Click="BrowseFile_Click" Margin="0,0,4,0" Padding="10,6" />
            <Button Content="フォルダ..." Click="BrowseFolder_Click" Padding="10,6" />
        </StackPanel>

        <!-- Arguments -->
        <TextBlock Grid.Row="4" Text="引数" />
        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="ArgsBox" />

        <!-- Position label -->
        <TextBlock Grid.Row="6" Grid.ColumnSpan="3"
                   x:Name="PositionLabel"
                   Foreground="#888" FontSize="11" />

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="クリア" Click="Clear_Click" Margin="0,0,8,0" />
            <Button Content="キャンセル" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="OK" Click="OK_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
